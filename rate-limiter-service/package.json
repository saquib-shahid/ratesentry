{
  "name": "ratesentry",
  "version": "1.0.6",
  "description": "Distributed Rate Limiter Middleware for Express",
  "main": "dist/src/lib.js",
  "types": "dist/src/lib.d.ts",
  "exports": {
    ".": {
      "require": "./dist/src/lib.js",
      "import": "./dist/src/lib.js",
      "types": "./dist/src/lib.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "keywords": [
    "rate-limiter",
    "express",
    "middleware",
    "redis",
    "sliding-window",
    "rate-limiting"
  ],
  "author": "saquib-shahid",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/saquib-shahid/ratesentry.git"
  },
  "homepage": "https://github.com/saquib-shahid/ratesentry#readme",
  "bugs": {
    "url": "https://github.com/saquib-shahid/ratesentry/issues"
  },
  "type": "module",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "mongoose": "^9.4.1",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
